<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            style="@style/SettingsSectionHeader"
            android:layout_marginTop="0dp"
            android:text="@string/ha_overlays_title" />

        <View style="@style/SettingsDivider" />

        <RelativeLayout
            android:id="@+id/btn_ha_overlay_1"
            style="@style/SettingsItem.Container.Clickable"
            android:focusable="true"
            android:nextFocusUp="@+id/tab_ha"
            android:nextFocusDown="@+id/btn_ha_overlay_2"
            android:nextFocusLeft="@+id/btn_ha_overlay_1"
            android:nextFocusRight="@+id/btn_ha_overlay_1">
            <TextView
                android:id="@+id/text_ha_overlay_1"
                style="@style/SettingsItem.Label"
                android:textColor="?attr/colorOnSurface" />
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/btn_ha_overlay_2"
            style="@style/SettingsItem.Container.Clickable"
            android:focusable="true"
            android:nextFocusUp="@+id/btn_ha_overlay_1"
            android:nextFocusDown="@+id/btn_ha_overlay_3"
            android:nextFocusLeft="@+id/btn_ha_overlay_2"
            android:nextFocusRight="@+id/btn_ha_overlay_2">
            <TextView
                android:id="@+id/text_ha_overlay_2"
                style="@style/SettingsItem.Label"
                android:textColor="?attr/colorOnSurface" />
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/btn_ha_overlay_3"
            style="@style/SettingsItem.Container.Clickable"
            android:focusable="true"
            android:nextFocusUp="@+id/btn_ha_overlay_2"
            android:nextFocusDown="@+id/btn_ha_overlay_4"
            android:nextFocusLeft="@+id/btn_ha_overlay_3"
            android:nextFocusRight="@+id/btn_ha_overlay_3">
            <TextView
                android:id="@+id/text_ha_overlay_3"
                style="@style/SettingsItem.Label"
                android:textColor="?attr/colorOnSurface" />
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/btn_ha_overlay_4"
            style="@style/SettingsItem.Container.Clickable"
            android:focusable="true"
            android:nextFocusUp="@+id/btn_ha_overlay_3"
            android:nextFocusLeft="@+id/btn_ha_overlay_4"
            android:nextFocusRight="@+id/btn_ha_overlay_4">
            <TextView
                android:id="@+id/text_ha_overlay_4"
                style="@style/SettingsItem.Label"
                android:textColor="?attr/colorOnSurface" />
        </RelativeLayout>

    </LinearLayout>
</ScrollView>
