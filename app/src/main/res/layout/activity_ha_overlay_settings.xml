<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">
    <LinearLayout
        android:orientation="vertical"
        android:paddingBottom="32dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/ha_overlay_settings_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/TextAppearance.AppCompat.Title"/>
        <RadioGroup
            android:orientation="horizontal"
            android:id="@+id/toggleGroup_settings_tabs"
            android:padding="8dp"
            android:focusable="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">
            <RadioButton
                android:id="@+id/tab_source"
                android:nextFocusRight="@+id/tab_display"
                android:nextFocusDown="@+id/switch_ha_overlay_enabled"
                android:checked="true"
                android:text="Quelle/Regeln"
                style="@style/SettingsItem.Tab"/>
            <requestFocus/>
            <RadioButton
                android:id="@+id/tab_display"
                android:nextFocusLeft="@+id/tab_source"
                android:nextFocusDown="@+id/container_ha_position"
                android:text="Darstellung/Layout"
                style="@style/SettingsItem.Tab"/>
        </RadioGroup>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/container_tab_source"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textColor="@color/m3_primary"
                android:text="Datenquelle"
                style="@style/SettingsSectionHeader"/>
            <View style="@style/SettingsDivider"/>
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_ha_overlay_enabled"
                android:nextFocusLeft="@+id/switch_ha_overlay_enabled"
                android:nextFocusRight="@+id/switch_ha_overlay_enabled"
                android:nextFocusUp="@+id/tab_source"
                android:text="@string/setting_enabled"
                style="@style/Widget.App.Switch"/>
            <RelativeLayout
                android:id="@+id/btn_ha_browse_entities"
                android:focusable="true"
                android:clickable="true"
                style="@style/SettingsItem.Container.Clickable">
                <TextView
                    android:textColor="?attr/colorOnSurface"
                    android:text="@string/ha_entity_browse_button"
                    style="@style/SettingsItem.Label"/>
                <TextView
                    android:textAppearance="?attr/textAppearanceBody2"
                    android:ellipsize="end"
                    android:id="@+id/text_ha_entity_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="250dp"
                    android:maxLines="2"
                    android:singleLine="false"
                    android:layout_centerVertical="true"
                    android:textAlignment="viewEnd"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>
            <LinearLayout
                android:id="@+id/container_ha_source"
                android:focusable="true"
                android:clickable="true"
                android:descendantFocusability="blocksDescendants"
                android:layout_marginTop="8dp"
                style="@style/SettingsItem.Container.Clickable">
                <TextView
                    android:text="Anzeige-Inhalt"
                    style="@style/SettingsItem.Label"/>
                <Spinner
                    android:id="@+id/spinner_ha_source"
                    android:focusable="false"
                    style="@style/SettingsItem.Spinner"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/container_ha_visibility_mode"
                android:focusable="true"
                android:clickable="true"
                android:descendantFocusability="blocksDescendants"
                android:layout_marginTop="8dp"
                style="@style/SettingsItem.Container.Clickable">
                <TextView
                    android:text="Sichtbarkeit"
                    style="@style/SettingsItem.Label"/>
                <Spinner
                    android:id="@+id/spinner_ha_visibility_mode"
                    android:focusable="false"
                    style="@style/SettingsItem.Spinner"/>
            </LinearLayout>
            <RelativeLayout
                android:id="@+id/btn_ha_trigger_entity"
                android:focusable="true"
                android:visibility="gone"
                android:clickable="true"
                style="@style/SettingsItem.Container.Clickable">
                <TextView
                    android:textColor="?attr/colorOnSurface"
                    android:text="Referenz-Entität"
                    style="@style/SettingsItem.Label"/>
                <TextView
                    android:textAppearance="?attr/textAppearanceBody2"
                    android:ellipsize="end"
                    android:id="@+id/text_ha_trigger_entity_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="200dp"
                    android:singleLine="true"
                    android:layout_centerVertical="true"
                    android:textAlignment="viewEnd"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/container_ha_trigger_state"
                android:visibility="gone"
                android:hint="Einblenden, wenn Zustand... (z.B. &apos;off&apos;)"
                style="@style/SettingsItem.TextInput">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edit_ha_trigger_state"
                    android:inputType="text"
                    style="@style/SettingsItem.TextInput.EditText"/>
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_current_trigger_state"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Aktueller Zustand wird geladen..."
                app:chipIcon="@android:drawable/ic_menu_edit"/>
            <Button
                android:textColor="?attr/colorOnSurface"
                android:id="@+id/btn_ha_value_mappings"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:text="Zustands-Regeln konfigurieren"
                android:drawableStart="@android:drawable/ic_menu_sort_by_size"
                android:drawableTint="?attr/colorOnSurface"
                android:layout_marginVertical="16dp"
                app:strokeColor="?attr/colorOnSurface"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/container_tab_display"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textColor="@color/m3_primary"
                android:text="Layout &amp; Ausrichtung"
                style="@style/SettingsSectionHeader"/>
            <View style="@style/SettingsDivider"/>
            <LinearLayout
                android:id="@+id/container_ha_position"
                android:focusable="true"
                android:nextFocusLeft="@+id/container_ha_position"
                android:nextFocusRight="@+id/container_ha_position"
                android:nextFocusUp="@+id/tab_display"
                android:clickable="true"
                android:descendantFocusability="blocksDescendants"
                style="@style/SettingsItem.Container.Clickable">
                <TextView
                    android:text="@string/setting_position_label"
                    style="@style/SettingsItem.Label"/>
                <Spinner
                    android:id="@+id/spinner_ha_position"
                    android:focusable="false"
                    style="@style/SettingsItem.Spinner"/>
            </LinearLayout>
            <RelativeLayout
                android:id="@+id/btn_ha_fine_tune"
                android:focusable="true"
                android:nextFocusLeft="@+id/btn_ha_fine_tune"
                android:nextFocusRight="@+id/btn_ha_fine_tune"
                android:clickable="true"
                style="@style/SettingsItem.Container.Clickable">
                <TextView
                    android:textColor="?attr/colorOnSurface"
                    android:text="@string/btn_fine_tune"
                    style="@style/SettingsItem.Label"/>
            </RelativeLayout>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/container_text_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textColor="@color/m3_primary"
                    android:layout_marginTop="16dp"
                    android:text="Text-Darstellung"
                    style="@style/SettingsSectionHeader"/>
                <View style="@style/SettingsDivider"/>
                <LinearLayout
                    android:id="@+id/container_ha_display_mode"
                    android:focusable="true"
                    android:nextFocusLeft="@+id/container_ha_display_mode"
                    android:nextFocusRight="@+id/container_ha_display_mode"
                    android:clickable="true"
                    android:descendantFocusability="blocksDescendants"
                    style="@style/SettingsItem.Container.Clickable">
                    <TextView
                        android:text="@string/ha_display_mode_label"
                        style="@style/SettingsItem.Label"/>
                    <Spinner
                        android:id="@+id/spinner_ha_display_mode"
                        android:focusable="false"
                        style="@style/SettingsItem.Spinner"/>
                </LinearLayout>
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/container_ha_display_name"
                    android:nextFocusLeft="@+id/container_ha_display_name"
                    android:nextFocusRight="@+id/container_ha_display_name"
                    android:hint="@string/ha_display_name_label"
                    style="@style/SettingsItem.TextInput">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_ha_display_name"
                        android:inputType="text"
                        style="@style/SettingsItem.TextInput.EditText"/>
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/container_ha_unit"
                    android:nextFocusLeft="@+id/container_ha_unit"
                    android:nextFocusRight="@+id/container_ha_unit"
                    android:hint="@string/ha_unit_label"
                    style="@style/SettingsItem.TextInput">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_ha_unit"
                        android:inputType="text"
                        style="@style/SettingsItem.TextInput.EditText"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/container_camera_settings"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textColor="@color/m3_primary"
                    android:text="Kamera-Einstellungen"
                    style="@style/SettingsSectionHeader"/>
                <View style="@style/SettingsDivider"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="12dp">
                    <LinearLayout
                        android:id="@+id/container_camera_stream_type"
                        android:focusable="true"
                        android:visibility="gone"
                        android:clickable="true"
                        android:descendantFocusability="blocksDescendants"
                        android:layout_marginBottom="16dp"
                        style="@style/SettingsItem.Container.Clickable">
                        <TextView
                            android:text="Stream-Typ"
                            style="@style/SettingsItem.Label"/>
                        <Spinner
                            android:id="@+id/spinner_camera_stream_type"
                            android:focusable="false"
                            style="@style/SettingsItem.Spinner"/>
                    </LinearLayout>
                    <TextView
                        android:id="@+id/textview_camera_interval_value"
                        android:paddingBottom="8dp"
                        android:text="Update-Intervall: 2s"
                        style="@style/SettingsItem.Label"/>
                    <SeekBar
                        android:id="@+id/seekbar_camera_interval"
                        android:nextFocusLeft="@+id/seekbar_camera_interval"
                        android:nextFocusRight="@+id/seekbar_camera_interval"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="59"/>
                </LinearLayout>
            </LinearLayout>
            <TextView
                android:textColor="@color/m3_primary"
                android:layout_marginTop="16dp"
                android:text="Design/Farben"
                style="@style/SettingsSectionHeader"/>
            <View style="@style/SettingsDivider"/>
            <include
                android:id="@+id/appearance_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                layout="@layout/include_settings_appearance"/>
        </LinearLayout>
        <View
            android:layout_marginTop="24dp"
            style="@style/SettingsDivider"/>
        <Button
            android:textColor="@color/m3_error"
            android:id="@+id/btn_reset_overlay"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Overlay zurücksetzen"
            app:strokeColor="@color/m3_error"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
