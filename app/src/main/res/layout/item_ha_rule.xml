<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="4dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="56dp">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:id="@+id/container_rule_content"
        android:background="?attr/selectableItemBackground"
        android:focusable="true"
        android:nextFocusRight="@+id/btn_delete_rule"
        android:clickable="true"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WENN: "
                android:alpha="0.7"/>
            <TextView
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:id="@+id/text_rule_condition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp">
            <TextView
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurface"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DANN: "
                android:alpha="0.7"/>
            <TextView
                android:textColor="?attr/colorOnSurface"
                android:id="@+id/text_rule_display"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
        <View
            android:id="@+id/view_rule_color_indicator"
            android:background="@drawable/color_picker_swatch"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="4dp"/>
    </LinearLayout>
    <ImageButton
        android:id="@+id/btn_delete_rule"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:focusable="true"
        android:nextFocusLeft="@+id/container_rule_content"
        android:clickable="true"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@android:drawable/ic_menu_delete"
        android:tint="@color/m3_error"
        android:contentDescription="Regel löschen"/>
</LinearLayout>
